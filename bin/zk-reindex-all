#!/usr/bin/env bash
# zk-reindex-all — auto-discover .zk/ notebooks and reindex each.
#
# Designed to run periodically (e.g. via launchd StartInterval=60).
# Stateless: each invocation does a fresh `find` for .zk/ directories.
# New notebooks created via `zk init` anywhere under the scan roots are
# picked up on the next cycle — no service restart needed.
#
# Performance: when nothing changed, zk uses mtime+size checks before
# re-parsing — typical run is <1s wall time and ~zero SSD writes.
#
# Configuration:
#   ~/.config/zk-reindex-launchd/notebooks.conf — primary config (if exists).
#     One root per line. Format: <path>[:<maxdepth>]
#     Lines starting with # are comments; blank lines are ignored.
#     Examples:
#       /Users/me/admin-technical          # full-depth scan
#       /Users/me/dev:2                    # only descend 2 levels (good for
#                                          #   <root>/<project>/.zk lookup;
#                                          #   skips deep repo subtrees)
#
# Env vars:
#   ZK_BIN                       Path to the `zk` binary. Default: zk on PATH.
#   ZK_REINDEX_CONFIG            Override config file path. Default:
#                                $XDG_CONFIG_HOME/zk-reindex-launchd/notebooks.conf
#                                (falls back to ~/.config/...).
#   ZK_REINDEX_ROOTS             Colon-separated list of roots to scan
#                                (no per-root depth control). Used only if
#                                no config file exists.
#   ZK_REINDEX_EXCLUDES          Colon-separated additional paths to prune.
#                                Merged with the built-in exclusion list.
#
# Resolution order: config file > ZK_REINDEX_ROOTS env var > defaults.
#
# Exit code: number of notebooks that errored during reindex (0 on success).

set -uo pipefail

ZK="${ZK_BIN:-zk}"
TIMESTAMP="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

if ! command -v "$ZK" >/dev/null 2>&1; then
  echo "[$TIMESTAMP] FATAL: zk not found (set ZK_BIN, or install via 'brew install zk')"
  exit 1
fi

# --- Roots + per-root depth --------------------------------------------------
# Build two parallel arrays: ROOT_PATHS (the paths) and ROOT_DEPTHS (maxdepth
# per root, "" means no limit). Resolution order:
#   1. Config file (~/.config/zk-reindex-launchd/notebooks.conf)
#   2. ZK_REINDEX_ROOTS env var (no per-root depth control)
#   3. Built-in defaults (common notebook locations)

ROOT_PATHS=()
ROOT_DEPTHS=()

CONFIG_FILE="${ZK_REINDEX_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/zk-reindex-launchd/notebooks.conf}"

if [[ -f "$CONFIG_FILE" ]]; then
  while IFS= read -r line || [[ -n "$line" ]]; do
    # Strip trailing whitespace; skip blank lines and comments.
    line="${line%%#*}"
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" ]] && continue

    if [[ "$line" =~ ^(.+):([0-9]+)$ ]]; then
      ROOT_PATHS+=("${BASH_REMATCH[1]}")
      ROOT_DEPTHS+=("${BASH_REMATCH[2]}")
    else
      ROOT_PATHS+=("$line")
      ROOT_DEPTHS+=("")
    fi
  done < "$CONFIG_FILE"
elif [[ -n "${ZK_REINDEX_ROOTS:-}" ]]; then
  IFS=':' read -ra _R <<< "$ZK_REINDEX_ROOTS"
  for r in "${_R[@]}"; do
    ROOT_PATHS+=("$r")
    ROOT_DEPTHS+=("")
  done
else
  for r in "$HOME/Documents" "$HOME/Desktop" "$HOME/notes" "$HOME/Notes" "$HOME/Obsidian" "$HOME/Vault"; do
    ROOT_PATHS+=("$r")
    ROOT_DEPTHS+=("")
  done
fi

# --- Exclusions: paths (top-level prunes under $HOME) ------------------------
# These are full paths whose entire subtree is skipped. macOS-flavored.
EXCLUDE_PATHS=(
  # Apple-managed system data, app prefs, iCloud cache, Mail, Containers,
  # CloudStorage (modern File Provider mounts for Drive/OneDrive/Box/Dropbox).
  "$HOME/Library"

  # Apple-bundled media libraries (and their parent folders, which never
  # contain dev docs anyway).
  "$HOME/Pictures"
  "$HOME/Music"
  "$HOME/Movies"

  # Legacy / rarely-used macOS folders.
  "$HOME/Applications"
  "$HOME/Public"
  "$HOME/Sites"
  "$HOME/Downloads"

  # Trash variants and Time Machine local snapshots.
  "$HOME/.Trash"
  "$HOME/.Trashes"
  "$HOME/.tmutil"
  "$HOME/.MobileBackups"

  # macOS volume metadata (can appear under $HOME on attached volumes).
  "$HOME/.fseventsd"
  "$HOME/.Spotlight-V100"
  "$HOME/.DocumentRevisions-V100"
  "$HOME/.TemporaryItems"

  # Legacy cloud-sync mount roots (modern installs use Library/CloudStorage,
  # already covered by the Library prune). SQLite-vs-sync race risk.
  "$HOME/Dropbox"
  "$HOME/.dropbox.cache"
  "$HOME/OneDrive"
  "$HOME/Box"
  "$HOME/Box Sync"
  "$HOME/pCloud Drive"
  "$HOME/Tresors"
  "$HOME/Sync"
  "$HOME/MEGA"
  "$HOME/Nextcloud"
  "$HOME/ownCloud"
  "$HOME/Resilio Sync"
  "$HOME/SynologyDrive"

  # Virtual machines (disk images can be tens of GB; never contain notebooks).
  "$HOME/.lume"
  "$HOME/.tart"
  "$HOME/.utm"
  "$HOME/.colima"
  "$HOME/.lima"
  "$HOME/.orbstack"
  "$HOME/OrbStack"
  "$HOME/Parallels"
  "$HOME/VirtualBox VMs"
  "$HOME/Virtual Machines.localized"
  "$HOME/.vagrant.d"
)

# Optional user-supplied extras
if [[ -n "${ZK_REINDEX_EXCLUDES:-}" ]]; then
  IFS=':' read -ra EXTRA <<< "$ZK_REINDEX_EXCLUDES"
  EXCLUDE_PATHS+=("${EXTRA[@]}")
fi

# --- Exclusions: directory names (pruned at any depth) -----------------------
EXCLUDE_NAMES=(
  # SCM internals
  .git .hg .svn

  # Package-manager / language caches
  node_modules .npm .pnpm-store .yarn .bun .deno
  .cargo .rustup .gem .nvm .rvm .pyenv
  .gradle .m2 .ivy2 .sbt
  .docker .vagrant .android
  .composer .stack .cabal .opam .swiftpm .zig-cache .zls-cache

  # Python virtualenvs and tool caches
  .venv venv __pycache__ .pytest_cache .mypy_cache .ruff_cache .ipynb_checkpoints
  .poetry .pdm .hatch .tox

  # JS framework build/run caches
  .expo .metro .parcel-cache .vite .astro .docusaurus .remix .cache-loader

  # Build artifacts
  target build dist out .next .nuxt .svelte-kit .turbo

  # Containers / Kubernetes
  .multipass .kube .minikube .podman .containers .rd

  # Cloud SDKs / IaC
  .terraform .terragrunt-cache .pulumi .serverless .azure .gcloud .helm .kustomize

  # Editors / IDEs (state, not code)
  .idea .zed .fleet .vscode-server .cursor-server

  # ML / model caches
  .ollama .huggingface

  # macOS volume metadata at any depth
  .fseventsd .Spotlight-V100 .DocumentRevisions-V100 .TemporaryItems

  # General caches
  .cache .ccache
)

# --- Bundle-name prunes (Apple "package" directories) ------------------------
# These look like directories on disk but are app-managed bundles. Pruning
# *.app alone is the single biggest scan-time saver since app bundles appear
# in dev tool installs (Xcode, Electron) outside ~/Applications.
EXCLUDE_GLOBS=(
  # Application + system code packages
  '*.app' '*.framework' '*.bundle' '*.kext' '*.plugin' '*.component'
  '*.mdimporter' '*.qlgenerator' '*.prefPane' '*.appex' '*.systemextension'

  # Apple media libraries
  '*.photoslibrary' '*.musiclibrary' '*.tvlibrary' '*.imovielibrary'
  '*.aplibrary' '*.lrlibrary'

  # Apple media projects
  '*.fcpbundle' '*.fcpevent' '*.fcpproject' '*.logicx' '*.band'

  # iWork (zip archives but appear as packages on macOS)
  '*.pages' '*.numbers' '*.key'

  # OmniGroup project bundles
  '*.graffle' '*.ooutline' '*.oplx'

  # Xcode bundles (the .xcworkspace/.xcodeproj are dirs)
  '*.xcworkspace' '*.xcodeproj'

  # VM bundles
  '*.pvm' '*.vmwarevm'

  # Disk images (sparsebundles especially are directory-shaped)
  '*.sparsebundle' '*.sparseimage'
)

# --- Build the find expression -----------------------------------------------
build_find_args() {
  local args=()
  local first=true
  for p in "${EXCLUDE_PATHS[@]}"; do
    if $first; then args+=( '(' -path "$p" ); first=false
    else            args+=( -o -path "$p" ); fi
  done
  for n in "${EXCLUDE_NAMES[@]}"; do
    if $first; then args+=( '(' -name "$n" ); first=false
    else            args+=( -o -name "$n" ); fi
  done
  for g in "${EXCLUDE_GLOBS[@]}"; do
    args+=( -o -name "$g" )
  done
  args+=( ')' -prune -o -name '.zk' -type d -print0 )
  printf '%s\n' "${args[@]}"
}

# --- Discover notebooks ------------------------------------------------------
mapfile -t FIND_ARGS < <(build_find_args)

raw=()
for i in "${!ROOT_PATHS[@]}"; do
  root="${ROOT_PATHS[$i]}"
  depth="${ROOT_DEPTHS[$i]}"
  [[ -d "$root" ]] || continue
  if [[ -n "$depth" ]]; then
    while IFS= read -r -d '' zk_dir; do
      raw+=("$(dirname "$zk_dir")")
    done < <(find "$root" -maxdepth "$depth" "${FIND_ARGS[@]}" 2>/dev/null)
  else
    while IFS= read -r -d '' zk_dir; do
      raw+=("$(dirname "$zk_dir")")
    done < <(find "$root" "${FIND_ARGS[@]}" 2>/dev/null)
  fi
done

# Dedupe nested notebooks: a child .zk/ inside another notebook (e.g. a git
# submodule that is itself a notebook clone) is skipped — the parent is
# canonical.
notebooks=()
for nb in "${raw[@]}"; do
  nested=false
  for other in "${raw[@]}"; do
    [[ "$nb" == "$other" ]] && continue
    if [[ "$nb" == "$other"/* ]]; then
      nested=true
      break
    fi
  done
  $nested || notebooks+=("$nb")
done

if [[ ${#notebooks[@]} -eq 0 ]]; then
  echo "[$TIMESTAMP] no notebooks under: ${ROOTS[*]}"
  exit 0
fi

# --- Reindex each ------------------------------------------------------------
errors=0
for nb in "${notebooks[@]}"; do
  if out=$(cd "$nb" && "$ZK" index 2>&1); then
    summary="$(echo "$out" | tail -1 | tr -s ' ')"
    echo "[$TIMESTAMP] $nb — $summary"
  else
    errors=$((errors + 1))
    echo "[$TIMESTAMP] $nb — ERROR: $(echo "$out" | tr '\n' ' ')"
  fi
done

exit "$errors"
